# Example environment variables (DO NOT commit real credentials)
# Copy to ".env" and fill with real values before running Docker/systemd/cron deployment.

# SEL API credentials
SEL_API_EMAIL=your-email@example.com
SEL_API_PASSWORD=your-password

# Daily production participants
DAILY_PARTICIPANTS=certhr5fwl7p,certhckoz1h4

# Optional daily overrides
DAILY_BASE_CONFIG=configs/active/release_eval.yaml
DAILY_HOUSE_OVERRIDES=configs/active/house_overrides_daily.example.yaml
DAILY_OUTPUT_DIR=DATA/daily_sel_api
DAILY_SPLIT=test
DAILY_TARGET_DATE=
DAILY_SAMPLING_MINUTES=1
DAILY_ENERGY_UNIT=kwh_per_interval
DAILY_OUTPUT_POWER_UNIT=w
DAILY_MAX_MISSING_RATIO=0.2
DAILY_ALLOWED_FINAL_MAINS_MISSING_RATIO=0.03
DAILY_INTERPOLATE_MAX_GAP_POINTS=3
DAILY_INTERPOLATE_METHOD=time
DAILY_KEEP_GOING=1
DAILY_KEEP_PARTICIPANT_FILTER=0
DAILY_FETCH_ONLY=0
DAILY_EVAL_ONLY=0
DAILY_MERGED_CSV=
DAILY_PRINT_ONLY=0
DAILY_RUN_DOCTOR=1
DAILY_DOCTOR_PARTICIPANT=

# Runtime timezone used by the daily container when DAILY_TARGET_DATE is empty.
TZ=Europe/Athens

# Optional build/runtime overrides
TORCH_VERSION=2.5.1
TORCH_INDEX_URL_CPU=https://download.pytorch.org/whl/cpu
TORCH_INDEX_URL_GPU=https://download.pytorch.org/whl/cu121
CUDA_VISIBLE_DEVICES=0

# Optional: make Docker outputs owned by your host user instead of root.
# On Linux you can set these with: id -u / id -g
LOCAL_UID=1000
LOCAL_GID=1000
